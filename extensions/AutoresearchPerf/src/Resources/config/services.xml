<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="AutoresearchPerf\StoreApi\ProductListRouteOptimizer"
                 decorates="Shopware\Core\Content\Product\SalesChannel\ProductListRoute">
            <argument type="service" id="AutoresearchPerf\StoreApi\ProductListRouteOptimizer.inner"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\ProductListingRouteOptimizer"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Listing\ResolveCriteriaProductListingRoute">
            <argument type="service" id="AutoresearchPerf\StoreApi\ProductListingRouteOptimizer.inner"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\DeferredProductListingCmsElementResolver"
                 decorates="Shopware\Core\Content\Product\Cms\ProductListingCmsElementResolver">
            <argument type="service" id="AutoresearchPerf\StoreApi\DeferredProductListingCmsElementResolver.inner"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\ProductListingCriteriaSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\ProductListingFilterTrimSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\HomeListingRequestSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\HomeListingDeferRequestSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\HomeListingDeferResponseSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\SessionCachePolicySubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\StoreApi\WidgetListingTrimSubscriber">
            <argument type="service" id="request_stack"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductSearchCriteriaSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductSearchSourceSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductEsSourceRegistry">
            <argument type="service" id="request_stack"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductSearchDalBypassSubscriber">
            <argument type="service" id="AutoresearchPerf\Admin\AdminProductEsSourceRegistry"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductEntityReaderDecorator"
                 decorates="Shopware\Core\Framework\DataAbstractionLayer\Read\EntityReaderInterface">
            <argument type="service" id="AutoresearchPerf\Admin\AdminProductEntityReaderDecorator.inner"/>
            <argument type="service" id="AutoresearchPerf\Admin\AdminProductEsSourceRegistry"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductGridSearchService">
            <argument type="service" id="OpenSearch\Client"/>
            <argument type="service" id="Shopware\Elasticsearch\Framework\ElasticsearchHelper"/>
            <argument type="service" id="Shopware\Core\Content\Product\ProductDefinition"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
        </service>

        <service id="AutoresearchPerf\Admin\AdminProductGridSearchController">
            <argument type="service" id="AutoresearchPerf\Admin\AdminProductGridSearchService"/>
            <tag name="controller.service_arguments"/>
        </service>
    </services>
</container>
